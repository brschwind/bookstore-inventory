# Square API Credentials (get from developer.squareup.com)
SQUARE_APPLICATION_ID=sandbox-sq0idb-YOUR_APP_ID_HERE
SQUARE_ACCESS_TOKEN=YOUR_SANDBOX_ACCESS_TOKEN_HERE

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/bookstore_inventory

# JWT Secret (use a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Server
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Square Environment
SQUARE_ENVIRONMENT=sandbox
